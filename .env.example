# Hetzner配置
HETZNER_TOKEN=your_hetzner_api_token

# 流量监控配置
TRAFFIC_LIMIT_TB=20
ROTATE_THRESHOLD=0.98
CHECK_INTERVAL_MINUTES=5
SAFE_MODE=true

# Telegram配置（可选）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SSH配置
SSH_USER=root
SSH_PORT=22

# Web认证配置
WEB_USERNAME=admin
WEB_PASSWORD=your_secure_password
SECRET_KEY=your_random_secret_key

# 进程监控（可选，逗号分隔）
MONITOR_PROCESSES=

# 其他配置
TZ=Asia/Shanghai
SNAPSHOT_PRICE_PER_GB=0.011

# 持久化会话配置
ENABLE_REMEMBER_ME=true
REMEMBER_ME_DAYS=7
MAX_REMEMBER_ME_DAYS=30
